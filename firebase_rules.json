{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": true,
        ".write": true
      }
    },
    "grids": {
      "$roomId": {
        ".read": true,
        ".write": true
      }
    },
    "cells": {
      "$roomId": {
        ".read": true,
        ".write": true,
        "$cellKey": {
          ".validate": "newData.hasChildren(['c', 'p', 't'])"
        }
      }
    }
  }
}
